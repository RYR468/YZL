# 益志领 · 环境变量模板
# ─────────────────────────────────────────────
# 用法:复制本文件为 .env,填入真实值。.env 已被 .gitignore 排除,不会入库。
# 生产部署:优先在平台(Zeabur Variables / systemd EnvironmentFile)注入这些变量,
#           不要把含密钥的 .env 文件留在工作目录或提交到 Git。

# Flask session 密钥(随机长字符串,可用 python -c "import secrets;print(secrets.token_hex(32))" 生成)
SECRET_KEY=

# 管理端登录密码 + 二级密码(审核招募/证书用,两者可不同;均必填,否则启动报错)
ADMIN_PASSWORD=
AUDIT_PASSWORD=

# 飞书自建应用凭证(https://open.feishu.cn)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_URL=
# 大群机器人 webhook(群里添加机器人后复制 webhook 地址)
FEISHU_GROUP_WEBHOOK=
FEISHU_GROUP_CHAT_ID=
# 三张多维表格的 token(导师/学生/匹配),整段 JSON 作为一个变量的值
FEISHU_TABLES_JSON={"mentor":{"app_token":"","table_id":""},"student":{"app_token":"","table_id":""},"match":{"app_token":"","table_id":""}}
